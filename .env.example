# ============================================================
#  MantlePulse environment — copy to ".env" and fill in.
# ============================================================

# ---- REQUIRED for deploy (Checkpoint 2) ----------------------------
# Private key of a FRESH, THROWAWAY wallet. NEVER use your main wallet.
# Accepts the 64-hex key with or without a leading 0x.
PRIVATE_KEY=

# Mantle Sepolia testnet RPC (default below is public + free; no key needed)
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# ---- Live data targets (optional; verified Mantle addresses baked in) ----------
# Mantle mainnet RPC used for READING live data (free, read-only).
MANTLE_DATA_RPC=https://rpc.mantle.xyz
# Verified Mantle mainnet token addresses (defaults are already set in config.js).
WMNT_TOKEN=0x78c1b0C915c4FAA5FffA6CAbf0219DA63d7f4cb8
CMETH_TOKEN=0xe6829d9a7ee3040e1276fa75293bde931859e8fa
# Add verified Mantle token/pool addresses to turn these cards fully live too
# (otherwise the agent safely simulates a liquidity index for the demo):
MERCHANT_MOE_TOKEN=
AGNI_TOKEN=

# ---- FILLED IN AUTOMATICALLY after deploy (see deployments.json) ----
IDENTITY_REGISTRY_ADDRESS=
SIGNAL_REGISTRY_ADDRESS=
AGENT_ID=1
AGENT_DOMAIN=mantlepulse.local

# ---- OPTIONAL (all free) -------------------------------------------
# Mantlescan API key — only if you verify via Mantlescan instead of the
# default Blockscout explorer (Blockscout needs no real key).
MANTLESCAN_API_KEY=

# Telegram bot token from @BotFather — enables the Telegram digest bot. Free.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# NOTE: No paid APIs are used. Alert text is generated by free templated logic,
# not a paid LLM. The whole project runs at $0.

# Mantle mainnet RPC — only if you choose to deploy to mainnet instead.
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
